rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // briefings — read-only for authenticated user, writes via Cloud Functions only
    match /briefings/{briefingId} {
      allow read:   if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // alerts — read/update for authenticated user, creates via Cloud Functions only
    match /alerts/{alertId} {
      allow read:   if isAuthenticated();
      allow update: if isAuthenticated();
      allow create: if false;
      allow delete: if false;
    }

    // tasks — full CRUD for authenticated user
    match /tasks/{taskId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // chatSessions — full CRUD for authenticated user
    match /chatSessions/{sessionId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // chatMessages — read-only for authenticated user, writes/deletes via Cloud Functions only
    match /chatMessages/{messageId} {
      allow read:   if isAuthenticated();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
